# Minimal Caddy reverse proxy with automatic TLS for Kammer.
# Replace kammer.example.org with your PHX_HOST.
#
# Pair this with TRUSTED_PROXIES in .env (e.g. TRUSTED_PROXIES=127.0.0.1
# for this same-host setup): Kammer honors X-Forwarded-For only from
# addresses listed there, so without it rate limiting treats all
# traffic as coming from the proxy's IP — one abusive client exhausts
# every user's signup/sign-in budget.

kammer.example.org {
	encode zstd gzip
	reverse_proxy localhost:4000

	# WebSockets (LiveView, /api/socket) are proxied automatically by
	# Caddy. The bundled Svelte web app is served by Phoenix itself at
	# /app — nothing extra to configure here.

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}
}
