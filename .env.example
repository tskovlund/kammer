# Kammer configuration — copy to .env and edit.
# Env always wins over wizard-collected settings (SPEC §13).

# ── Required ────────────────────────────────────────────────────────────────

# Public hostname of your instance (no scheme), e.g. kammer.example.org
PHX_HOST=localhost

# Cookie/token signing secret. Generate with:
#   docker run --rm kammer:latest /app/bin/kammer eval "IO.puts :crypto.strong_rand_bytes(48) |> Base.encode64()"
# or: mix phx.gen.secret
SECRET_KEY_BASE=

# Database password (compose wires user/db automatically)
POSTGRES_PASSWORD=

# ── Email (magic-link sign-in requires working outbound email) ──────────────

# "smtp" (default) or "local" (in-memory mailbox — evaluation only!)
MAILER_ADAPTER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_SSL=true            # implicit TLS (usually port 465)
MAIL_FROM_ADDRESS=kammer@example.org
MAIL_FROM_NAME=Kammer

# ── Optional ────────────────────────────────────────────────────────────────

# Published HTTP port on the host
KAMMER_HTTP_PORT=4000

# Postgres overrides (rarely needed with compose)
POSTGRES_USER=kammer
POSTGRES_DB=kammer

# Nightly backups (04:15 UTC) land here when set; see docs/backups.md
# BACKUP_DIR=/backups
# BACKUP_KEEP=14
# BACKUP_AGE_RECIPIENT=

# Daily check (05:00 UTC) against GitHub releases, surfaced to instance
# operators as a banner. Opt-out: set to "true" or "1" to disable — no
# payload is ever sent beyond the version fetch either way.
# DISABLE_UPDATE_CHECK=

# File storage: "local" (default) or "s3" (MinIO/Hetzner/any S3-compatible)
STORAGE_ADAPTER=local
# UPLOADS_PATH=/app/uploads
# S3_ENDPOINT=http://minio:9000
# S3_BUCKET=kammer
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1

# Upload size limit in megabytes (SPEC §7, default 100). Enforced
# per-file by the app; the endpoint's multipart parser has a hard
# 128 MB request-body ceiling above it, so raising this past ~120
# needs that ceiling raised too (lib/kammer_web/endpoint.ex).
# UPLOAD_MAX_MB=100

# JSON API CORS: any origin may call /api/v1 by default (auth is a Bearer
# device token, never a cookie — see issue #150). Set to a comma-separated
# list of origins (scheme://host[:port], no path) to restrict which
# web-client origins the browser may call from. Empty means unrestricted.
# API_ALLOWED_ORIGINS=https://app.example.org

# Reverse proxy addresses (comma-separated IPs or CIDRs). Rate limits
# key on the client IP; behind a proxy that IP is only visible through
# X-Forwarded-For — a spoofable header, so it is honored only when the
# connection comes from an address listed here. Set it to your proxy's
# address as the app sees it: 127.0.0.1 for a same-host proxy like the
# docs/deploy/Caddyfile.example setup, or the proxy container's IP
# when it runs in Docker. Keep the list as narrow as possible — every
# address in a listed range gains the right to speak for clients, so
# a whole-subnet CIDR hands that right to every container on the
# network, not just the proxy — and never list a range your clients
# live in: their own forwarded entries would be skipped as proxy hops
# and collapse back onto shared limiting. Leave unset when clients reach Kammer
# directly — the header is then ignored entirely. An invalid entry
# fails the boot.
# TRUSTED_PROXIES=127.0.0.1,::1

# MinIO root credentials (only with --profile minio)
# MINIO_ROOT_USER=kammer
# MINIO_ROOT_PASSWORD=

# Instance defaults (also settable in the setup wizard; env wins).
# Unrecognized values fail the boot instead of being silently dropped.
# INSTANCE_NAME=Kammer
# DEFAULT_LOCALE=en          # en | da
# COMMUNITY_CREATION_POLICY=operators_only   # operators_only | any_user
# STORAGE_POLICY=unmetered   # unmetered | quota (per-community upload quotas)

# Promoted to instance operator on every boot — a privilege-granting
# side effect, so point it only at the operator's own account.
# OPERATOR_EMAIL=you@example.org

# Web Push (optional; push is disabled without keys). Generate with:
#   mix web_push.vapid
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.org
