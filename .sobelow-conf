[
  verbose: false,
  private: false,
  skip: true,
  router: "lib/kammer_web/router.ex",
  exit: "low",
  format: "txt",
  # Config.HTTPS: TLS terminates at the reverse proxy (deployment model).
  # Traversal.FileModule / Traversal.SendFile: Kammer.Storage.Local guards
  #   every path against escaping the uploads root; storage keys are
  #   server-generated UUID paths, never user input.
  # Traversal.SendDownload: the one send_download/2 call (GdprController)
  #   streams a zip whose path is built entirely inside Kammer.Gdpr.export/1
  #   (System.tmp_dir!/0 joined with the current user's id and a monotonic
  #   integer) — never derived from request params.
  # XSS.ContentType: stored content types pass a sanitizing allowlist and
  #   non-image files are served with Content-Disposition: attachment and
  #   X-Content-Type-Options: nosniff (KammerWeb.FileController).
  # Misc.BinToTerm: Kammer.Accounts.login_user_by_passkey/5 decodes a
  #   passkey's own public_key_cose column with the [:safe] option — data
  #   this same code wrote at registration, never request input, so there
  #   is no untrusted-deserialization boundary here.
  # Config.CSP: a real, strict CSP is set on every request by
  #   KammerWeb.Plugs.CspNonce (pre-1.0 hardening: nonce-based script-src,
  #   no 'unsafe-inline') — Sobelow's static check only recognizes a
  #   literal content-security-policy key in the put_secure_browser_headers
  #   call, so it can't see a header set by a separate plug. Verified with
  #   test/kammer_web/plugs/csp_nonce_test.exs and a real-browser check
  #   (zero console CSP violations, inline theme script executes).
  ignore: [
    "Config.HTTPS",
    "Traversal.FileModule",
    "Traversal.SendFile",
    "Traversal.SendDownload",
    "XSS.ContentType",
    "Misc.BinToTerm",
    "Config.CSP"
  ],
  ignore_files: []
]
